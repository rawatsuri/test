NODE_ENV=development
PORT=5000
LOG_LEVEL=debug
DATABASE_URL="postgresql://postgres:postgresql@127.0.0.1:5432/voice_platform?schema=public"
MASTER_ENCRYPTION_KEY=replace_with_at_least_32_characters_long_key
INTERNAL_API_SECRET=replace_with_at_least_16_characters

# Local auth
JWT_SECRET=my_super_secure_secret_that_is_at_least_32_chars

# Pipecat voice runtime
PIPECAT_BASE_URL=http://localhost:3001
# Optional public/media-stream URL. Leave blank to derive from PIPECAT_BASE_URL.
PIPECAT_STREAM_URL=
# Optional outbound bridge URL. Only required if you want backend-triggered outbound calls.
# Example: http://localhost:3000/create_call
PIPECAT_OUTBOUND_CALL_URL=
PIPECAT_API_KEY=

# Exotel (Indian telephony) — get from https://my.exotel.com
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api
EXOTEL_WEBHOOK_SECRET=

# Plivo (global telephony) — get from https://console.plivo.com
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_WEBHOOK_SECRET=

# Twilio (global telephony)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_SECRET=
PUBLIC_WEBHOOK_BASE_URL=

# Sarvam AI (Indian STT/TTS) — get from https://dashboard.sarvam.ai
SARVAM_API_KEY=

# Deepgram (STT) — get from https://console.deepgram.com
DEEPGRAM_API_KEY=

# OpenAI (LLM)
OPENAI_API_KEY=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# Optional providers
GROQ_API_KEY=
ANTHROPIC_API_KEY=
CARTESIA_API_KEY=

# Optional
REDIS_URL=
