OPENAI_API_KEY=
GROQ_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=en-US-JennyNeural
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
SARVAM_API_KEY=
