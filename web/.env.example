VITE_CLERK_PUBLISHABLE_KEY=
VITE_API_URL=http://localhost:5000

# Local development defaults
# auth=mock lets the dashboard sign in without Clerk
# data=mock keeps the full UI usable even where backend APIs are not implemented yet
VITE_AUTH_MODE=mock
VITE_DATA_MODE=mock

# Legacy fallback. Prefer VITE_DATA_MODE going forward.
VITE_USE_MOCK_DATA=true
