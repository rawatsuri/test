VITE_API_URL=http://localhost:5001

# Local development defaults
# auth=mock bypasses the backend login and signs in with local demo identities
# auth=local uses the backend email/password login
# data=mock keeps the full UI usable even where backend APIs are not implemented yet
VITE_AUTH_MODE=local
VITE_DATA_MODE=api

# Legacy fallback. Prefer VITE_DATA_MODE going forward.
VITE_USE_MOCK_DATA=false
